{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "hooks/**/*.mjs",
    "scripts/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "tasks"
  ]
}
